<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="page narrow-page">
  <section class="panel">
    <h1>Регистрация</h1>
    <%- include('../partials/flash') %>
    <form method="post" action="/register" class="stack-form">
      <label>
        <span>Имя</span>
        <input type="text" name="firstName" value="<%= form.firstName || '' %>" autocomplete="given-name" required>
      </label>
      <label>
        <span>Фамилия</span>
        <input type="text" name="lastName" value="<%= form.lastName || '' %>" autocomplete="family-name" required>
      </label>
      <label>
        <span>Логин</span>
        <input type="text" name="login" value="<%= form.login || '' %>" autocomplete="username" required>
      </label>
      <label>
        <span>Пароль</span>
        <input type="password" name="password" autocomplete="new-password" minlength="6" required>
      </label>
      <button type="submit" class="primary-button">Создать аккаунт</button>
    </form>
    <p class="muted">Уже есть аккаунт? <a href="/login">Войти</a></p>
  </section>
</main>

<%- include('../partials/footer') %>
